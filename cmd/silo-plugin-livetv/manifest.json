{
  "plugin_id": "silo.livetv",
  "version": "0.1.9",
  "checksum": "__CHECKSUM__",
  "silo_api_version": "v1",
  "category": "Video/LiveTV",
  "supported_platforms": [
    {
      "os": "linux",
      "arch": "amd64"
    }
  ],
  "capabilities": [
    {
      "type": "http_routes.v1",
      "id": "portal",
      "display_name": "Live TV",
      "description": "IPTV / M3U live TV portal with XMLTV EPG."
    },
    {
      "type": "scheduled_task.v1",
      "id": "refresh_m3u_sources",
      "display_name": "Refresh M3U sources",
      "cron": "0 */6 * * *",
      "description": "Re-downloads configured M3U playlists on schedule and refreshes the channel table."
    },
    {
      "type": "scheduled_task.v1",
      "id": "refresh_xmltv_sources",
      "display_name": "Refresh XMLTV sources",
      "cron": "0 */3 * * *",
      "description": "Re-downloads configured XMLTV EPG feeds on schedule and refreshes program data."
    },
    {
      "type": "scheduled_task.v1",
      "id": "reap_idle_sessions",
      "display_name": "Reap idle stream sessions",
      "cron": "* * * * *",
      "description": "Closes live-TV stream sessions whose clients have stopped pulling segments."
    }
  ],
  "http_routes": [
    {
      "id": "healthz",
      "method": "GET",
      "path": "/healthz",
      "access": "public"
    },
    {
      "id": "stream_bytes",
      "method": "GET",
      "path": "/api/v1/livetv/stream/*",
      "access": "public"
    },
    {
      "id": "admin_api",
      "method": "*",
      "path": "/api/v1/livetv/admin/*",
      "access": "admin",
      "navigable": true,
      "navigation_kind": "admin",
      "navigation_label": "Live TV"
    },
    {
      "id": "api",
      "method": "*",
      "path": "/api/v1/livetv/*",
      "access": "authenticated",
      "navigable": true,
      "navigation_kind": "user",
      "navigation_label": "Live TV"
    }

  ],
  "global_config_schema": []
}
